{
  "name": "@compactbiz/api",
  "version": "1.0.0",
  "private": true,
  "author": "Dusan <antovic95@gmail.com>",
  "homepage": "https://github.com/dusanantovic/compactbiz-api#readme",
  "license": "ISC",
  "main": "index.js",
  "engines": {
    "node": "22.4.0",
    "npm": "10.8.1"
  },
  "scripts": {
    "start": "cd ./dist && node index.js",
    "build": "rimraf --glob ./dist/* && npx webpack --config webpack.config.module.js && npm run migration",
    "start:dev": "npm run build && npm run start",
    "dev": "npm run dev:watch",
    "dev:watch": "nodemon -e ts --exec npm run dev:run",
    "dev:run": "ts-node ./index.ts",
    "typeorm": "ts-node ./node_modules/typeorm/cli",
    "migration-create": "npm run typeorm migration:create migrations/$npm_config_name",
    "migration-generate": "npm run typeorm -- -d ./dataSourceInstance.ts migration:generate migrations/$npm_config_name",
    "migration": "npm run typeorm migration:run -- -d ./dataSourceInstance.ts",
    "migration-revert": "npm run typeorm -- -d ./dataSourceInstance.ts migration:revert",
    "heroku-postbuild": "npm install && npm run build"
  },
  "dependencies": {
    "@babel/preset-typescript": "7.16.0",
    "@koa/cors": "^5.0.0",
    "body-parser": "^1.20.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^6.0.1",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "nodemailer-smtp-transport": "^2.7.4",
    "pg": "^8.10.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "6.0.1",
    "routing-controllers": "^0.10.2",
    "socket.io": "^4.8.3",
    "ts-loader": "^9.3.1",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "typeorm": "^0.3.12",
    "typescript": "^4.9.5",
    "url-pattern": "^1.0.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.0.2",
    "webpack-dev-server": "^4.13.3"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/kcors": "^2.2.5",
    "@types/multer": "^1.4.7",
    "@types/node": "^16.11.7",
    "@types/nodemailer": "^6.4.14",
    "@types/nodemailer-smtp-transport": "^2.7.8",
    "@types/pg": "^8.6.6",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/eslint-plugin-tslint": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "eslint": "^8.37.0",
    "eslint-config-standard-with-typescript": "^34.0.1",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsdoc": "^40.1.1",
    "eslint-plugin-n": "^15.7.0",
    "eslint-plugin-promise": "^6.1.1",
    "html-loader": "^4.2.0",
    "nodemon": "^2.0.20",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dusanantovic/compactbiz-api.git"
  },
  "bugs": {
    "url": "https://github.com/dusanantovic/compactbiz-api/issues"
  }
}
