{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug compactbiz-api",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/compactbiz-api/index.ts"
            ],
            "stopOnEntry": false,
            "runtimeArgs": [
                "--nolazy",
                "-r",
                "ts-node/register",
                "--preserve-symlinks"
            ],
            "env": {
                "TS_NODE_IGNORE": "\/node_modules\/",
                "TS_NODE_FILES": "true"
            },
            "sourceMaps": true,
            "cwd": "${workspaceRoot}/compactbiz-api",
            "skipFiles": [
                "<node_internals>/**/*.js"
            ]
        }
    ]
}