{
  "name": "@compactbiz/client",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.4.0",
    "npm": "10.8.1"
  },
  "scripts": {
    "start": "serve -s dist",
    "start:dev": "npx cross-env NODE_OPTIONS=--max-old-space-size=8192 ENVIRONMENT=local npx webpack serve --config webpack.config.module.js --port 3000",
    "build": "rimraf --glob ./dist/* && npx webpack --config webpack.config.module.js",
    "heroku-postbuild": "npm install && npm run build",
    "inject-models": "rimraf --glob ./models/* && shx cp -R ../compactbiz-api/models/ ./"
  },
  "dependencies": {
    "@babel/preset-typescript": "7.16.0",
