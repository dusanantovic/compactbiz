    "webpack": "^5.89.0",
    "webpack-cli": "^5.0.2",
    "webpack-dev-server": "^4.13.3",
    "rimraf": "6.0.1",
    "shx":"0.3.4"
  },
  "devDependencies": {
    "@babel/core": "7.16.0",
    "@babel/plugin-proposal-decorators": "7.16.4",
